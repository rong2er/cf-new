                        } catch (e) { }
                    }

                    const sizeMB = size ? (size / 1024 / 1024).toFixed(2) + 'MB' : '未知大小';
                    return { ...q, available: true, url: url, urlKey: url.split('?')[0], size: size, sizeStr: sizeMB };
                }
                return null;
            } catch (e) { return null; }
        });

        const results = await Promise.all(checkPromises);
        let validResults = results.filter(r => r !== null);

        const urlMap = new Map();
        const sizeMap = new Map();
        const unique = [];

        for (const r of validResults) {
            if (urlMap.has(r.urlKey)) continue;
            if (r.size && r.size > 0 && sizeMap.has(r.size)) {
