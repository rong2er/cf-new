            }
            urlMap.set(r.urlKey, r);
            if (r.size > 0) sizeMap.set(r.size, r);
            unique.push(r);
        }

        // 定义音质权重：jymaster > dolby > sky > jyeffect > hires > lossless > exhigh > higher > standard
        const qWeight = { jymaster: 10, dolby: 9, sky: 8, jyeffect: 7, hires: 6, lossless: 5, exhigh: 4, higher: 3, standard: 2 };
        
        // 按权重从高到低排序打印日志
        unique.sort((a, b) => (qWeight[b.level] || 0) - (qWeight[a.level] || 0));
        unique.forEach(r => {
