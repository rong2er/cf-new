// --- 高级 HMAC 签名算法 ---
async function generateToken(path, timestamp) {
    const msg = `${path}:${timestamp}`;
    const encoder = new TextEncoder();
    const keyData = encoder.encode(API_KEY);
    const msgData = encoder.encode(msg);
    
    // 导入密钥
    const cryptoKey = await crypto.subtle.importKey(
        'raw', keyData, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']
    );
    // 生成签名
    const signature = await crypto.subtle.sign('HMAC', cryptoKey, msgData);
    // 转为 Hex
    return Array.from(new Uint8Array(signature)).map(b => b.toString(16).padStart(2, '0')).join('');
}

// --- AES-GCM 解密逻辑 ---
async function decryptData(encryptedBase64, ivBase64) {
    try {
        const keyData = new TextEncoder().encode(API_KEY);
        const hash = await crypto.subtle.digest('SHA-256', keyData);
        const key = await crypto.subtle.importKey('raw', hash, { name: 'AES-GCM' }, false, ['decrypt']);
        
        const iv = new Uint8Array(atob(ivBase64).split('').map(c => c.charCodeAt(0)));
        const data = new Uint8Array(atob(encryptedBase64).split('').map(c => c.charCodeAt(0)));
        
        const decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: iv }, key, data);
        return new TextDecoder().decode(decrypted);
    } catch (e) {
        console.warn("Decryption failed:", e);
        return null;
    }
}

// --- 核心请求函数 (带安全校验) ---
async function req(url, options = {}) {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), options.timeout || 15000);

    try {
        // 兼容性修复：如果在本地 file:// 环境下执行，或传入的是内部 api 路径，自动补全域名
        let baseUrl = window.location.origin;
        if (baseUrl === "null" || url.startsWith("/v1/")) {
            baseUrl = API_CF_WORKER;
        }
        
        const u = new URL(url, baseUrl);
        const ts = Math.floor(Date.now() / 1000);
        
        // 判定逻辑：只要是发往核心 Worker 的请求，一律加签
        const isWorker = u.origin === API_CF_WORKER;
        
        if (isWorker) {
            const token = await generateToken(u.pathname, ts);
            
            // 极致隐形化：不再拼接 URL 参数，改为 Header 注入鉴权
            options.headers = options.headers || {};
            options.headers['X-Auth-Token'] = token;
            options.headers['X-Auth-Timestamp'] = ts.toString();
            
            // 终极 V4：强制转为 POST，将所有 Query 参数（id, action 等）移入 Body
            if (u.search) {
                options.method = "POST";
                options.headers['Content-Type'] = 'application/x-www-form-urlencoded';
                options.body = u.searchParams.toString();
                
                // 清空 URL 参数，使其在网络面板显示的地址绝对“纯白”
                url = u.origin + u.pathname;
            } else {
                url = u.toString();
            }
        }

        const response = await fetch(url, options);
        clearTimeout(timeoutId);

        if (!response.ok) {
            if (response.status === 403) {
                const errData = await response.json().catch(() => ({}));
                console.error("Worker Access Denied:", errData.reason || "Unknown", errData);
            }
            throw new Error(`HTTP Error: ${response.status}`);
        }

        const contentType = response.headers.get("content-type");
        const xIv = response.headers.get("X-Data-IV");
        
        let data;
        if (isWorker && xIv) {
            // 如果有加密头，执行解密
            const encryptedText = await response.text();
            const decryptedText = await decryptData(encryptedText, xIv);
            data = decryptedText ? JSON.parse(decryptedText) : encryptedText;
        } else {
            // 普通处理
            data = (contentType && contentType.includes("application/json")) ? 
                         await response.json() : await response.text();
        }

        // --- 自动日志曝光 (调试增强) ---
        if (isWorker && !options.quiet) {
            const urlObj = new URL(url, API_CF_WORKER);
            let label = urlObj.pathname;
            
            // 智能识别：提取歌名和音质，避免“千篇一律”
            if (data && typeof data === 'object') {
                const songName = data.name || (data.songs && data.songs[0]?.name) || "";
                const qLevel = data.level || (data.data && data.data[0]?.level) || "";
                if (songName) label += ` [${songName}${qLevel ? ' - ' + qLevel : ''}]`;
                else if (data.msg) label += ` (${data.msg})`;
            }
            
            console.log(`📡 [API Response] ${label}:`, data);
        }
                     
        return (typeof data === 'string' && data.trim().startsWith('{')) ? JSON.parse(data) : data;

    } catch (error) {
        if (error.name === 'AbortError') throw new Error("连接超时 (15s)");
        throw error;
    } finally {
        clearTimeout(timeoutId);
    }
}

