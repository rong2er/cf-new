async function loadArtistList(resetPage = false) {
    const type = document.getElementById('artist-type-filter').value;
    const area = document.getElementById('artist-area-filter').value;
    const initial = document.getElementById('artist-initial-filter').value;

    // 如果筛选条件变了，重置 offset
    if (resetPage || !state.artistList) {
        state.artistList = {
            all: [], // 缓存当前页数据
            offset: 0, // 当前偏移量
            limit: 32, // 固定每页32
            currentFilters: { type, area, initial } // 记录当前筛选
        };
    } else {
        // 检查筛选条件是否变化，如果变化则强制重置
        const f = state.artistList.currentFilters;
        if (f.type !== type || f.area !== area || f.initial !== initial) {
            state.artistList.offset = 0;
            state.artistList.currentFilters = { type, area, initial };
        }
    }

    state.artistFilters = { type, area, initial };
    const container = document.getElementById('artists-grid');

    // 显示骨架屏
    container.innerHTML = renderArtistSkeleton(32);
    document.getElementById('pg-artists').style.display = 'none'; // 加载时隐藏分页

    try {
        const limit = state.artistList.limit;
        const offset = state.artistList.offset;
        const res = await req(`${API_CF_WORKER}/v1/index/artist.bin?type=${type}&area=${area}&initial=${initial}&limit=${limit}&offset=${offset}`);

        if (res && res.artists && res.artists.length > 0) {
            state.artistList.all = res.artists; // 仅保存当前页数据
            // 渲染Tiles
            renderArtistTiles(res.artists);
            // 更新分页控件
            updateArtistPagination(res.more);
        } else {
            container.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">暂无歌手数据</div>';
            document.getElementById('pg-artists').style.display = 'none';
        }
    } catch (e) {
        console.error(e);
        container.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">加载失败，请重试</div>';
    }
}

