async function loadPageDetails(slice) {
    const tasks = slice.map(async (s) => {
        if (s.source === 'netease' || s.source === 'netease_album') {
            if (s.pic && s.pic.includes('http') && s.duration !== "00:00") return;
            try {
                // Priority 1: Cloudflare Worker (Guest Mode)
                const res = await req(`${API_CF_WORKER}/v1/data/song_detail.bin?id=${s.id}`);
                const songData = (res.songs && res.songs[0]) ? res.songs[0] : res;

                let coverUrl = (songData.al && songData.al.picUrl) || (songData.album && songData.album.picUrl) || songData.pic || "";
                let duration = songData.dt || songData.duration || 0;

                if (!coverUrl && !duration) throw new Error("Worker data empty or invalid");

                if (duration) { s.duration = formatDuration(duration); const timeEl = document.getElementById(`time-${s.id}`); if (timeEl) timeEl.innerText = s.duration; }
                if (coverUrl) { s.pic = coverUrl.replace(/^http:\/\//, 'https://'); const imgEl = document.getElementById(`cover-${s.id}`); if (imgEl) { imgEl.src = s.pic; imgEl.classList.add('loaded'); } }
            } catch (err) {
                // 如果 Worker 获取不到就算了，后续播放时会尝试解析
                console.warn(`Worker Metadata info not found for ${s.id}`);
            }
        }
        else if (!s.pic || s.pic.includes("Cb69B9")) {
            const match = await smartMatchNetease(s.name, s.artist);
            if (match && match.pic) { s.pic = match.pic; s.netease_id = match.id; const imgEl = document.getElementById(`cover-${s.id}`); if (imgEl) { imgEl.src = s.pic; imgEl.classList.add('loaded'); } }
        }
    }); await Promise.all(tasks);
}

