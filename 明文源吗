// 音质检测器模块

class QualityDetector {
    constructor() {
        this.cache = new Map();
        this.cacheExpiry = 30 * 60 * 1000; // 30分钟
    }

    getCacheKey(song) {
        return `${song.source || 'netease'}_${song.id}`;
    }

    isCacheValid(cacheItem) {
        if (!cacheItem) return false;
        return (Date.now() - cacheItem.timestamp) < this.cacheExpiry;
    }

    async detectQualities(song, overrideApi = null) {
        const cacheKey = this.getCacheKey(song);
        const cached = this.cache.get(cacheKey);

        if (!overrideApi && this.isCacheValid(cached)) {
            console.log(`[QualityDetector] 使用缓存:`, song.name);
            return cached.qualities;
        }

        console.log(`[QualityDetector] 分析中...`, overrideApi ? `(M: ${overrideApi})` : '');
        const source = song.source || 'netease';
        let qualities = [];

        try {
            // ★★★ Check Override API First (For Recovery) ★★★
            if (overrideApi) {
                if (source === 'netease' || source === 'netease_album') {
                    // Special handling for GDMUSIC/SAYQZ if passed as override, but usually it's a URL
                    if (overrideApi === API_CF_DIRECT || overrideApi.includes('/song/url')) {
                        qualities = await this.checkDirectQualities(song.id);
                        if (!qualities || qualities.length === 0) qualities = await this.checkWyapiQualities(song.id, overrideApi);
                    } else if (overrideApi.includes('gdm')) {
                        qualities = await this.checkGDStudioQualities('netease', song.id);
                    } else if (overrideApi.includes('sayqz')) {
                        qualities = await this.checkSayqzQualities('netease', song.id);
                    } else {
                        qualities = await this.checkWyapiQualities(song.id, overrideApi);
                    }
                } else if (source === 'qq' || source === 'kuwo') {
                    // Override for QQ/Kuwo usually implies forcing a specific API test
                    if (overrideApi.includes('sayqz')) qualities = await this.checkSayqzQualities(source, song.id);
                }

                // If we have an override, we return immediately after this block
                this.cache.set(cacheKey, { qualities, timestamp: Date.now() });
                return qualities;
            }

            // ★★★ Check User Preferred API First ★★★
            if (window.state && window.state.preferredApi) {
                const pApi = window.state.preferredApi;
                console.log(`[QualityDetector] Prioritizing User API: ${pApi}`);

                if (source === 'netease' || source === 'netease_album') {
                    if (pApi === 'proxy') qualities = await this.checkWyapiQualities(song.id, API_PROXY);
                    else if (pApi === 'direct') qualities = await this.checkDirectQualities(song.id);

                    else if (pApi === 'sayqz') qualities = await this.checkSayqzQualities('netease', song.id);
                    else if (pApi === 'gdstudio') qualities = await this.checkGDStudioQualities('netease', song.id);
                } else {
                    // Non-Netease
                    if (pApi === 'sayqz') qualities = await this.checkSayqzQualities(source, song.id);
                    else if (pApi === 'gdstudio') qualities = await this.checkGDStudioQualities(source, song.id);
                }

                if (qualities && qualities.length > 0) {
                    console.log(`[QualityDetector] User API (${pApi}) found ${qualities.length} qualities.`);
                    this.cache.set(cacheKey, { qualities, timestamp: Date.now() });
                    return qualities;
                }
                console.warn(`[QualityDetector] User API (${pApi}) returned no results, falling back...`);
            }

            if (source === 'netease' || source === 'netease_album') {
                // --- Dynamic Priority Check based on API_PRIORITY_LIST ---
                if (typeof API_PRIORITY_LIST === 'undefined') {
                    console.error("API_PRIORITY_LIST missing! Check api.js");
                    return this.getDefaultQualities(source);
                }

                for (const provider of API_PRIORITY_LIST) {
                    // 静默运行，不再打印 Provider 信息

                    try {
                        if (provider.type === 'cyrui') {
                            qualities = await this.checkCyruiQualities(song.id);
                        } else if (provider.type === 'xuan') {
                            qualities = await this.checkXuanQualities(song.id);
                        } else if (provider.type === 'rrvenn') {
                            qualities = await this.checkRrvennQualities(song.id);
                        } else if (provider.type === 'proxy') {
                            qualities = await this.checkWyapiQualities(song.id, provider.api);
                        } else if (provider.type === 'gd') {
                            qualities = await this.checkGDStudioQualities('netease', song.id);
                        } else if (provider.type === 'direct') {
                            qualities = await this.checkDirectQualities(song.id);
                        }

                        if (qualities && qualities.length > 0) {
                            // console.log(`[QualityDetector] Success`);
                            this.cache.set(cacheKey, { qualities, timestamp: Date.now() });
                            return qualities;
                        }
                    } catch (e) {
                        console.warn(`[QualityDetector] Provider ${provider.name} error:`, e);
                    }
                }

                console.warn("[QualityDetector] All providers failed.");

            } else if (source === 'kuwo' || source === 'qq') {
                qualities = await this.checkSayqzQualities(source, song.id);
            }

            this.cache.set(cacheKey, { qualities, timestamp: Date.now() });
            return qualities;
        } catch (error) {
            console.error(`[QualityDetector] 失败:`, error);
            return this.getDefaultQualities(source);
        }
    }

    async checkWyapiQualities(songId, apiUrl) {
        const levels = [
            { level: 'standard', tag: 'MP3', name: '标准音质' },
            { level: 'higher', tag: 'MP3', name: '较高音质' },
            { level: 'exhigh', tag: 'MP3', name: '极高音质' },
            { level: 'lossless', tag: 'FLAC', name: '无损音质' },
            { level: 'hires', tag: 'Hi-Res', name: '高清无损' },
            { level: 'jyeffect', tag: 'Surround', name: '高清臻音' },
            { level: 'sky', tag: 'Spatial Audio', name: '沉浸环绕声' },
            { level: 'dolby', tag: 'Dolby Atmos', name: '杜比全景声' },
            { level: 'jymaster', tag: 'Master', name: '超清母带' }
        ];

        const checkPromises = levels.map(async (q) => {
            try {
                // Also support API_CF_DIRECT (Direct) which needs 'br' and returns Array
                const url = `${apiUrl}?id=${songId}&level=${q.level}&br=${q.level}`;
                const res = await req(url);
                let actualUrl = null;

                if (typeof res === 'string' && res.startsWith('http')) actualUrl = res;
                else if (res && Array.isArray(res.data) && res.data[0] && res.data[0].url) actualUrl = res.data[0].url;
                else if (res) actualUrl = (res.url || res.data?.url);
                if (actualUrl) actualUrl = actualUrl.replace(/^http:\/\//, 'https://'); // Force HTTPS for size check reliability

                // Try to get size from API response (Support both Object and Array formats)
                let sizeStrRaw = 0;
                if (res && Array.isArray(res.data) && res.data[0]) sizeStrRaw = res.data[0].size || res.data[0].fileSize || 0;
                else if (res) sizeStrRaw = res.size || res.data?.size || 0;

                let size = 0;
                if (sizeStrRaw) {
                    let matchStr = sizeStrRaw.toString().replace(/,/g, '');
                    const numMatch = matchStr.match(/(\d+(\.\d+)?)/);
                    const numVal = numMatch ? parseFloat(numMatch[1]) : 0;
                    const lowerStr = matchStr.toLowerCase();

                    if (lowerStr.includes('gb')) size = numVal * 1024 * 1024 * 1024;
                    else if (lowerStr.includes('mb')) size = numVal * 1024 * 1024;
                    else if (lowerStr.includes('kb')) size = numVal * 1024;
                    else {
                        if (numVal > 1024 * 10) size = parseInt(numVal, 10);
                        else size = parseInt(numVal, 10) * 1024 * 1024;
                    }
                }

                if (actualUrl && actualUrl.length > 10) {
                    // 1. Verify Real Quality from URL Parameter (Source of Truth)
                    // The API returns the ACTUAL level in the url params, e.g. "...&level=standard"
                    // We must use this to correct our label if we asked for 'dolby' but got 'standard'.
                    // This fixes the issue where the user sees "Dolby" but the URL is actually Standard.
                    let finalLevel = q.level;
                    let finalName = q.name;
                    let finalTag = q.tag;

                    // 1. Verify Real Quality from URL Parameter (Source of Truth)
                    // Support parsing 'level' OR 'br' from the URL (e.g. ...&br=lossless or ...&level=standard)
                    const match = actualUrl.match(/[?&](?:level|br)=([^&]+)/);
                    if (match && match[1]) {
                        // match[1] is the capturing group for the value
                        const realLevel = match[1];
                        if (realLevel !== q.level) {
                            // Find the config for the REAL level
                            const correctConfig = levels.find(l => l.level === realLevel);
                            if (correctConfig) {
                                finalLevel = correctConfig.level;
                                finalName = correctConfig.name;
                                finalTag = correctConfig.tag;
                            }
                        }
                    }

                    // Define probeUrl: Use Proxy if Direct Link to avoid CORS
                    let probeUrl = actualUrl;
                    if (probeUrl.includes('.music.126.net') || probeUrl.includes('.myqcloud.com') || probeUrl.includes('music.163.com')) {
                        probeUrl = `${API_CF_WORKER}/util/download?url=${encodeURIComponent(probeUrl)}&filename=probe.mp3`;
                    }

                    // Try to get size from HEAD request first
                    if (!size || size === 0) {
                        try {
                            const controller = new AbortController();
                            const timeoutId = setTimeout(() => controller.abort(), 2000);
                            const headRes = await fetch(probeUrl, { method: 'HEAD', signal: controller.signal });
                            clearTimeout(timeoutId);
                            const len = headRes.headers.get('content-length');
                            if (len) size = parseInt(len, 10);
                        } catch (e) { }
                    }

                    // If HEAD failed (likely CORS or 405), try GET with Range or immediate abort
                    if (!size || size === 0) {
                        try {
                            const controller = new AbortController();
                            const timeoutId = setTimeout(() => controller.abort(), 2000);
                            // Use probeUrl here too
                            const getRes = await fetch(probeUrl, { method: 'GET', signal: controller.signal, headers: { 'Range': 'bytes=0-0' } });
                            clearTimeout(timeoutId);
                            const len = getRes.headers.get('content-length');
                            if (len) size = -1; // Just mark as available if we got a 206/200
                        } catch (e) { }
                    }


                    const sizeMB = size ? (size / 1024 / 1024).toFixed(2) + 'MB' : 'NaNMB';

                    return {
                        level: finalLevel,
                        name: finalName,
                        tag: finalTag,
                        available: true,
                        url: actualUrl,
                        urlKey: actualUrl.split('?')[0],
                        size: size,
                        sizeStr: sizeMB
                    };
                }
                return null;
            } catch (e) {
                return null;
            }
        });

        const results = await Promise.all(checkPromises);
        const validResults = results.filter(r => r !== null);

        // URL Deduplication & Size Validation
        const urlMap = new Map();
        console.groupCollapsed(`[QualityDetector] ${songId} 检测结果(原始: ${validResults.length} 个)`);

        // 1. Group by URL Key (Gather all levels pointing to same URL)
        for (const q of validResults) {
            if (!urlMap.has(q.urlKey)) {
                urlMap.set(q.urlKey, {
                    url: q.url,
                    urlKey: q.urlKey,
                    size: q.size,
                    sizeStr: q.sizeStr,
                    levels: [q.level],
                    tags: [q]
                });
            } else {
                const entry = urlMap.get(q.urlKey);
                if (!entry.levels.includes(q.level)) entry.levels.push(q.level);
                entry.tags.push(q);
                // Update size if we found it in a later request logic
                if ((!entry.size || entry.size === 0) && q.size > 0) {
                    entry.size = q.size;
                    entry.sizeStr = q.sizeStr;
                }
            }
        }

        // 2. Process Values into Unique List
        const unique = [];
        // const priorityOrder = ['jymaster', 'dolby', 'sky', 'jyeffect', 'hires', 'lossless', 'exhigh', 'higher', 'standard'];

        for (const entry of urlMap.values()) {
            // Determine the "True" name for this URL
            // DEFAULT RULE: If multiple quality levels point to the SAME URL, assume it's the LOWEST quality in the group.
            // This prevents "Standard" files from being labeled "Dolby" just because the API returned the same fallback URL for both.

            const qualityHierarchy = ['standard', 'higher', 'exhigh', 'lossless', 'hires', 'jyeffect', 'sky', 'dolby', 'jymaster'];

            // Sort standard->master (0->N). 0 is lowest quality.
            // Sort standard->master (0->N). 0 is lowest quality.
            entry.levels.sort((a, b) => qualityHierarchy.indexOf(a) - qualityHierarchy.indexOf(b));

            // Default: Pick lowest quality as safe fallback
            let bestLevel = entry.levels[0];

            // ★ Priority Rule: If URL explicitly contains the level name, TRUST IT ★
            // This ensures if URL says '&br=jymaster', we pick 'jymaster' even if it was also grouped with 'lossless'
            for (const lvl of entry.levels) {
                if (entry.url.includes(`br=${lvl}`) || entry.url.includes(`level=${lvl}`)) {
                    bestLevel = lvl;
                    // Also skip size check for explicit matches if we trust the API
                    break;
                }
            }

            // Size Validation Rules (Secondary Check)
            // If we somehow didn't have 'standard' in the group but size is tiny (e.g. 3MB 'dolby'), downgrade it.
            // Size Validation Rules (Secondary Check)
            // Tier 1: Lossless/Master should be > 15MB (conservative, some FLACs are small but usually not <15MB for full songs)
            if (entry.size > 0 && entry.size < 15 * 1024 * 1024) {
                const losslessQualities = ['jymaster', 'dolby', 'sky', 'jyeffect', 'hires', 'lossless'];
                if (losslessQualities.includes(bestLevel)) {
                    console.log(`⚠️ Size Mismatch (Lossless): [${bestLevel}] is only ${entry.sizeStr}. Downgrading to ExHigh.`);
                    bestLevel = 'exhigh'; // Downgrade to 320k first
                }
            }
            // Tier 2: ExHigh (320k) should be > 3MB (Short songs can be ~4MB)
            if (entry.size > 0 && entry.size < 3 * 1024 * 1024) {
                if (bestLevel === 'exhigh') {
                    console.log(`⚠️ Size Mismatch (ExHigh): [${bestLevel}] is only ${entry.sizeStr}. Downgrading to Standard.`);
                    bestLevel = 'standard';
                }
            }

            // Find the original tag object for the chosen level (or fallback)
            let q = entry.tags.find(t => t.level === bestLevel);
            if (!q) {
                // If we forced a level (e.g. 'standard') that wasn't in list, create a synthetic one
                q = { ...entry.tags[0], level: bestLevel, name: '标准音质', tag: 'MP3' };
                // Fix map names if needed
                if (bestLevel === 'higher') { q.name = '较高音质'; q.tag = 'MP3'; }
                if (bestLevel === 'exhigh') { q.name = '极高音质'; q.tag = 'MP3'; }
            }

            // Update size info in the final object
            q.size = entry.size;
            q.sizeStr = entry.sizeStr;

            unique.push(q);
            console.log(`✅ Unique: [${q.level}] ${q.name} - ${q.sizeStr} `);
        }

        // 3. Final Sort by Size (Descending)
        // This ensures the BIGGEST file (Master) is always first, then High-Res, then Standard
        // 3. Final Sort by Size (Descending) + Priority Fallback
        // This ensures the BIGGEST file (Master) is always first.
        // If sizes are equal (e.g. 0/NaN), use Hierarchy Preference.
        const qualityHierarchy = ['jymaster', 'dolby', 'sky', 'jyeffect', 'hires', 'lossless', 'exhigh', 'higher', 'standard'];

        unique.sort((a, b) => {
            // Force strict number conversion to avoid NaN issues
            const sA = Number(a.size) || 0;
            const sB = Number(b.size) || 0;
            const sizeDiff = sB - sA;

            // If valid size difference exists, use it
            if (sizeDiff !== 0) return sizeDiff;

            // Priority Sort (Index 0 = Best = First)
            const idxA = qualityHierarchy.indexOf(a.level);
            const idxB = qualityHierarchy.indexOf(b.level);

            // Handle cases where level is not in hierarchy (push to end)
            const safeA = idxA === -1 ? 999 : idxA;
            const safeB = idxB === -1 ? 999 : idxB;

            return safeA - safeB;
        });

        // 4. Final Deduplication by Name (Prevent multiple 'Standard' or same-label entries)
        const finalUnique = [];
        const seenNames = new Set();
        for (const item of unique) {
            if (!seenNames.has(item.name)) {
                finalUnique.push(item);
                seenNames.add(item.name);
            } else {
                console.log(`⚠️ Removing Duplicate Label: ${item.name} (${item.sizeStr})`);
            }
        }

        console.groupEnd();

        // ★ FIXED: Removed fallback to checkSayqzQualities
        // The calling function (detectQualities) handles the fallback chain. 
        // Returning [] here allows it to proceed to Priority 2 (Proxy) etc.
        return finalUnique.length > 0 ? finalUnique : [];
    }

    async checkSayqzQualities(source, songId) {
        const levels = [
            { level: 'standard', tag: 'MP3', name: '标准音质', br: '128k' },
            { level: 'exhigh', tag: 'MP3', name: '极高音质', br: '320k' },
            { level: 'lossless', tag: 'FLAC', name: '无损音质', br: 'flac' },
            { level: 'hires', tag: 'Hi-Res', name: 'Hi-Res', br: 'flac24bit' }
        ];

        const checkPromises = levels.map(async (q) => {
            const testUrl = `${API_SAYQZ}/?type=url&source=${source}&id=${songId}&br=${q.br}`;
            try {
                // 1. Try Normal HEAD (Works on Local/HTTP, or if Redirect is HTTPS)
                const response = await fetch(testUrl, { method: 'HEAD' });

                if (response.ok && response.url && !response.url.includes('error')) {
                    const len = response.headers.get('content-length');
                    let size = len ? parseInt(len, 10) : 0;
                    const sizeMB = size ? (size / 1024 / 1024).toFixed(2) + 'MB' : '未知大小';

                    // Check if final URL is HTTP but we are on HTTPS
                    let finalUrl = response.url;
                    if (window.location.protocol === 'https:' && finalUrl.startsWith('http:')) {
                        // Upgrade known domains
                        if (finalUrl.includes('qqmusic.qq.com')) finalUrl = finalUrl.replace('http:', 'https:');
                        // Do NOT wrap in proxy if it causes 403
                    }

                    return { ...q, available: true, url: finalUrl, urlKey: finalUrl.split('?')[0], size: size, sizeStr: sizeMB };
                }
            } catch (e) {
                // 2. Mixed Content / CORS Error Fallback
                // Try opaque redirect check (confirms existence, but no size/url info)
                try {
                    const response = await fetch(testUrl, { method: 'HEAD', redirect: 'manual' });
                    if (response.type === 'opaqueredirect' || response.status === 0) {
                        // Authenticated existence
                        // Return original URL (allow browser mixed content warning rather than broken 403)
                        return {
                            ...q,
                            available: true,
                            url: testUrl,
                            urlKey: testUrl, // Use request URL as key since we rely on it
                            size: 0,
                            sizeStr: '未知'
                        };
                    }
                } catch (e2) { }
            }
            return null;
        });

        const results = await Promise.all(checkPromises);
        const validResults = results.filter(r => r !== null);

        // URL去重与"假无损"过滤逻辑 - v2
        const urlMap = new Map();
        const unique = [];
        console.groupCollapsed(`[QualityDetector] Sayqz ${source} - ${songId} 检测结果`);

        // 按质量等级排序：低 -> 高
        const levelOrder = ['standard', 'exhigh', 'lossless', 'hires', 'sky', 'jyeffect', 'dolby', 'jymaster'];
        validResults.sort((a, b) => levelOrder.indexOf(a.level) - levelOrder.indexOf(b.level));

        const sizeMap = new Map();

        for (const q of validResults) {
            if (urlMap.has(q.urlKey)) {
                const existing = urlMap.get(q.urlKey);
                console.log(`❌ URL重复 (已过滤): [${q.level}] 与 [${existing.level}] URL相同`);
                continue;
            }

            if (q.size && q.size > 0 && sizeMap.has(q.size)) {
                const existing = sizeMap.get(q.size);
                console.log(`❌ 虚假音质 (已过滤): [${q.level}] 大小(${q.sizeStr}) 与 [${existing.level}] 相同 -> 视为假源`);
                continue;
            }

            urlMap.set(q.urlKey, q);
            if (q.size > 0) sizeMap.set(q.size, q);
            unique.push(q);
            console.log(`✅ 有效: [${q.level}] ${q.name} - ${q.sizeStr} (Size: ${q.size})`);
        }

        unique.sort((a, b) => {
            // Force strict number conversion
            const sA = Number(a.size) || 0;
            const sB = Number(b.size) || 0;
            const sizeDiff = sB - sA;
            if (sizeDiff !== 0) return sizeDiff;

            // Fallback: Priority Sort
            const idxA = levelOrder.indexOf(a.level);
            const idxB = levelOrder.indexOf(b.level);
            // Higher index in levelOrder = Better quality (based on array definition above)
            return idxB - idxA;
        });
        console.groupEnd();

        return unique.length > 0 ? unique : this.getDefaultQualities(source);
    }

