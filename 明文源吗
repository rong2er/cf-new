async function loadArtistAlbums(artistId, reset = false) {
    const albumsContainer = document.getElementById('artist-albums-grid');
    const pgContainer = document.getElementById('pg-artist-albums');
    const pgInfo = document.getElementById('pg-info-artist-albums');

    if (reset || !state.artistAlbums || state.artistAlbums.id !== artistId) {
        state.artistAlbums = {
            id: artistId,
            offset: 0,
            limit: 32, // 4行 x 8列
            all: [], // 缓存当前页
            total: 0
        };
    }

    if (state.artistAlbums.all.length === 0) {
        albumsContainer.innerHTML = renderArtistSkeleton(32);
        pgContainer.style.display = 'none';
    }

    try {
        const limit = state.artistAlbums.limit;
        const offset = state.artistAlbums.offset;
        const res = await req(`${API_CF_WORKER}/v1/data/album_list.bin?id=${artistId}&limit=${limit}&offset=${offset}`);

        if (res && res.hotAlbums && res.hotAlbums.length > 0) {
            const html = res.hotAlbums.map(album => {
                const picUrl = (album.picUrl || album.blurPicUrl || '').replace(/^http:/, 'https:');
                return `<div class="tile lazy-loading" 
                            style="--img: url('${PLACEHOLDER_IMG}')" 
                            data-lazy-img="${picUrl}"
                            onclick="loadAlbumDetail(${album.id}, '${(album.name || '').replace(/'/g, "\\'")}', ${artistId})">
                            <div class="tile-text">${album.name}</div>
                            <div class="tile-badge">${formatDate(album.publishTime)}</div>
                            <div class="tile-count-badge">${album.size}首</div>
                        </div>`;
            }).join('');

            albumsContainer.innerHTML = html;

            const currentPage = Math.floor(offset / limit) + 1;
            pgInfo.innerText = `第 ${currentPage} 页`;
            pgContainer.style.display = 'flex';

            setTimeout(() => observeLazyTiles(), 100);

        } else {
            albumsContainer.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">暂无专辑数据</div>';
            if (offset === 0) {
                pgContainer.style.display = 'none';
            } else {
                const currentPage = Math.floor(offset / limit) + 1;
                pgInfo.innerText = `第 ${currentPage} 页 (End)`;
                pgContainer.style.display = 'flex';
            }
        }
    } catch (e) {
        console.error('加载专辑失败:', e);
        albumsContainer.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">加载失败，请重试</div>';
        if (state.artistAlbums.offset > 0) {
            pgContainer.style.display = 'flex';
        } else {
            pgContainer.style.display = 'none';
        }
    }
}

async function loadAlbumDetail(albumId, albumName, artistId) {
    document.getElementById('artist-detail-view').style.display = 'none';
    document.getElementById('album-detail-view').style.display = 'block';
    document.getElementById('album-name-display').innerText = albumName;

    state.currentAlbum = { id: albumId, name: albumName, artistId, songs: [] };
    state.pg['album-songs'] = 0; // 重置页码

    const container = document.getElementById('album-songs-container');
    container.innerHTML = renderSongListSkeleton(10);
    document.getElementById('pg-album-songs').style.display = 'none';

    try {
        const res = await req(`${API_CF_WORKER}/v1/data/album_meta.bin?id=${albumId}`);

        let songs = [];
        if (res && res.songs) {
            songs = res.songs;
        } else if (res && res.album && res.album.songs) {
            songs = res.album.songs;
        }

        if (songs && songs.length > 0) {
            const processedSongs = processRawSongs(songs.map(s => ({ ...s, source: 'netease' })));
            state.currentAlbum.songs = processedSongs;
            renderAlbumSongs();
        } else {
            container.innerHTML = '<div style="text-align:center;padding:40px;opacity:0.6">暂无歌曲</div>';
        }
    } catch (e) {
        console.error('加载专辑详情失败:', e);
        container.innerHTML = '<div style="text-align:center;padding:40px;opacity:0.6">加载失败</div>';
    }
}

async function loadLrc(s, id = null, src = null) {
    const targetId = id || s.id; const targetSrc = src || s.source; let lyricText = "";

    // --- 针对 Sayqz 源 (QQ) 的特殊处理 ---
    // 注意：网易云源 (netease) 已移除，优先走下方的自建 Worker 接口
    if (targetSrc === 'qq') {
        try {
            const apiUrl = `${API_SAYQZ}/?source=${targetSrc}&id=${targetId}&type=lrc`;
            const resp = await fetch(apiUrl);
            const rawText = await resp.text();

            try {
                const json = JSON.parse(rawText);
                if (json.data) lyricText = json.data;
                else if (json.lrc) lyricText = json.lrc;
            } catch (e) {
                lyricText = rawText;
            }
        } catch (e) { console.warn("Sayqz 歌词获取异常:", e); }
    }

    if (!lyricText && (targetSrc === 'netease' || s.netease_id)) {
        const realId = targetSrc === 'netease' ? targetId : s.netease_id;
        console.groupCollapsed(`[Lyric] 开始获取歌词: ${realId}`);

        // Priority 1: CF Worker /lyric (User Verified)
        try {
            console.log("[Lyric] 尝试 Priority 1 (CF Worker)...");
            const res = await req(`${API_CF_WORKER}/v1/static/lrc.dat?id=${realId}`);
            if (res) lyricText = (res.lrc && res.lrc.lyric) || res.lyric || "";
            if (lyricText) console.log("[Lyric] Priority 1 成功");
        } catch (e) { console.warn("[Lyric] Priority 1 失败/跳过:", e.message); }

        // Priority 2: Cyrui (Direct GET) - Backup
        if (!lyricText) {
            try {
                console.log("[Lyric] 尝试 Priority 2 (Cyrui)...");
                const res = await req(`${API_CYRUI}/getLyric.php?id=${realId}`);
                if (res) lyricText = (res.lrc && res.lrc.lyric) || res.lyric || "";
                if (lyricText) console.log("[Lyric] Priority 2 成功");
            } catch (e) { console.warn("[Lyric] Priority 2 失败:", e.message); }
        }

        // Priority 3: Xuanluoge (Direct GET)
        if (!lyricText) {
            try {
                console.log("[Lyric] 尝试 Priority 3 (Xuanluoge)...");
                const res = await req(`${API_XUAN}?miss=lyric&id=${realId}`);
                if (res) lyricText = (res.lrc && res.lrc.lyric) || res.lyric || "";
                if (lyricText) console.log("[Lyric] Priority 3 成功");
            } catch (e) { console.warn("[Lyric] Priority 3 失败:", e.message); }
        }

        // Priority 4: GDMusic
        if (!lyricText) {
            try {
                console.log("[Lyric] 尝试 Priority 4 (GDMusic)...");
                const res = await req(`${API_GDMUSIC}?types=lyric&id=${realId}&source=netease`);
                if (res && res.lyric) lyricText = res.lyric;
                if (lyricText) console.log("[Lyric] Priority 4 成功");
            } catch (e) { console.warn("[Lyric] Priority 4 失败:", e.message); }
        }

        console.groupEnd();
    }

    // 1. 解析歌词
    let parsed = lyricText.split('\n').map(x => {
        const m = /\[(\d+):(\d+)(\.\d+)?\](.*)/.exec(x);
        return m ? { t: parseInt(m[1]) * 60 + parseFloat(m[2]), c: m[4].trim() } : null;
    }).filter(x => x && x.c);

    // 2. 排序
    parsed.sort((a, b) => a.t - b.t);

    // 3. 智能合并同时间轴歌词 (修复翻译遮挡原词问题)
    const merged = [];
    const hasChinese = (str) => /[\u4e00-\u9fa5]/.test(str);

    for (let i = 0; i < parsed.length; i++) {
        const curr = parsed[i];
        const next = parsed[i + 1];

        // 如果下一句时间相同 (误差0.2s内)，且两句都不为空
        if (next && Math.abs(next.t - curr.t) < 0.2) {
            let main = curr.c;
            let sub = next.c;

            // 逻辑: 如果当前句含中文而下一句不含(纯英文/其他)，则下一句应该是原词，当前句是翻译
            // 交换位置，让原词在上面(Main)
            if (hasChinese(curr.c) && !hasChinese(next.c)) {
                main = next.c;
                sub = curr.c;
            }

            // 合并显示
            merged.push({
                t: curr.t,
                c: `${main}<br><span style="font-size:0.75em; opacity:0.6; font-weight:normal">${sub}</span>`
            });
            i++; // 跳过下一句
        } else {
            merged.push(curr);
        }
    }

    state.lrc = merged;
    // WRAP TEXT IN SPAN AND REMOVE INLINE ONCLICK (Delegate to mobile-logic.js)
    document.getElementById('lrc-content').innerHTML = state.lrc.length ?
        state.lrc.map((l, i) => `<p class="lrc" data-idx="${i}"><span>${l.c}</span></p>`).join('') :
        '<p class="lrc">纯音乐 / 无歌词</p>';
}

async function fetchAndDownload(btn, level, tag) {
    const originalText = btn.innerHTML;
    btn.innerHTML = `<span style="color:var(--c-player-main)"><i class="fas fa-spinner fa-spin"></i> 解析中...</span>`;

    const s = state.list[state.index];
    let currentSrc = s.source || state.src;
    if (currentSrc === 'netease_album') currentSrc = 'netease';

    try {
        let url = "";
        let ext = (level === 'lossless' || level === 'hires' || level === 'jymaster') ? "flac" : "mp3";

        // ★★★ 优先使用 QualityDetector 的缓存结果 (最高优先级) ★★★
        if (typeof qualityDetector !== 'undefined' && qualityDetector) {
            const cacheKey = qualityDetector.getCacheKey(s);
            const cached = qualityDetector.cache.get(cacheKey);
            if (cached && qualityDetector.isCacheValid(cached)) {
                // 尝试找完全匹配的音质
                let targetQual = cached.qualities.find(q => q.level === level);
                if (targetQual && targetQual.url) {
                    url = targetQual.url;
                    console.log(`[Download] 命中检测缓存: ${level} -> ${url}`);
                }
            }
        }

        // 如果检测器里没拿到 URL，再走 API Fallback 链 (Dynamic Priority List)
        if (!url && ['netease', 'netease_album'].includes(currentSrc)) {
            if (typeof API_PRIORITY_LIST !== 'undefined') {
                for (const provider of API_PRIORITY_LIST) {
                    if (url) break; // Found valid URL
                    console.log(`[Download] Trying ${provider.name}...`);

                    try {
                        if (provider.type === 'cyrui') {
                            const res = await req(`${API_CYRUI}/getMusicUrl.php?id=${s.id}&level=${level}`);
                            if (res && res.data && res.data[0] && res.data[0].url) {
                                url = res.data[0].url.replace('http://', 'https://');
                            }
                        }
                        else if (provider.type === 'rrvenn') {
                            const res = await req(`${API_RRVENN}?action=music&url=${s.id}&id=${s.id}&level=${level}&type=json`);
                            if (res && res.url) {
                                url = res.url.replace('http://', 'https://');
                            }
                        }
                        else if (provider.type === 'xuan') {
                            const res = await req(`${API_XUAN}?miss=getMusicUrl&id=${s.id}&level=${level}`);
                            if (res && res.data && res.data[0] && res.data[0].url) {
                                url = res.data[0].url.replace('http://', 'https://');
                            }
                        }
                        else if (provider.type === 'main' || provider.type === 'proxy') {
                            // Use provider.api
                            const res = await req(`${provider.api}?id=${s.id}&level=${level}`);
                            if (typeof res === 'string' && res.startsWith('http')) url = res;
                            else if (res && (res.url || (res.data && res.data.url))) url = res.url || res.data.url;
                            if (url) url = url.replace('http://', 'https://');
                        }
                        else if (provider.type === 'gd') {
                            const gdSrc = (currentSrc === 'qq') ? 'qq' : 'netease';
                            const res = await req(`${API_GDMUSIC}?types=url&id=${s.id}&source=${gdSrc}&level=${level}`);
                            if (res && res.url) url = res.url.replace('http://', 'https://');
                        }
                        else if (provider.type === 'direct') {
                            const res = await req(`${API_CF_WORKER}/v1/assets/manifest.bin?id=${s.id}&br=${level}`);
                            if (res && res.data && res.data[0] && res.data[0].url) {
                                url = res.data[0].url.replace('http://', 'https://');
                            }
                        }

                        if (url) console.log(`[Download] Success with ${provider.name}`);
                    } catch (e) {
                        console.warn(`[Download] ${provider.name} failed:`, e);
                    }
                }
            } else {
                console.warn("API_PRIORITY_LIST missing in download context");
            }
        }

        if (url) {
            // 简单的后缀修正
            if (url.includes('.flac')) ext = 'flac';
            else if (url.includes('.m4a')) ext = 'm4a';
            else if (url.includes('.wav')) ext = 'wav';
            else if (level.includes('master') || level.includes('hires')) ext = 'flac';
        }

        if (!url) throw new Error("无有效链接");

        // 生成友好的文件名：歌手 - 歌曲名.扩展名
        const sanitize = (str) => str.replace(/[\\/:*?"<>|]/g, '_'); // 移除Windows非法字符
        const filename = `${sanitize(s.artist)} - ${sanitize(s.name)}.${ext}`;

        // 显示sidebar底部的下载进度
        const progressContainer = document.getElementById('download-progress-sidebar');
        const filenameEl = document.getElementById('download-filename-sidebar');
        const statusEl = document.getElementById('download-status-sidebar');
        const progressBar = document.getElementById('download-progress-bar-sidebar');

        filenameEl.textContent = filename;
        statusEl.textContent = '准备下载...';
        progressBar.style.width = '0%';
        progressContainer.style.display = 'block';

        // 关闭下载选择弹窗
        document.getElementById('pop-download').classList.remove('show');

        // ★ Logic: Determine Download Method
        // 1. Default: Direct Download
        let downloadUrl = url;

        // 2. QQ Music: Force HTTPS to avoid Mixed Content (Direct Link)
        if (downloadUrl.includes('.qq.com') && downloadUrl.startsWith('http:')) {
            downloadUrl = downloadUrl.replace('http:', 'https:');
        }

        // 3. 网易云：代理 music.163.com 避免 Blob Fetch 跨域失败
        if (downloadUrl.includes('music.163.com') && typeof API_CF_WORKER !== 'undefined') {
            downloadUrl = `${API_CF_WORKER}/v1/audio/stream.dat?url=${encodeURIComponent(downloadUrl)}&filename=${encodeURIComponent(filename)}`;
        }

        // ★ CRITICAL FIX: Ensure downloadUrl is valid before creating the link.
        // Clicking an empty <a> tag causes the page to refresh/reload.
        if (!downloadUrl || downloadUrl.trim() === "") {
            throw new Error("无法获取有效的下载链接");
        }

        // ★ Usage: Force Download (Try Blob first, Fallback to New Tab)
        // 浏览器直接打开 MP3/FLAC URL 默认是播放。要强制下载，必须用 Blob 伪造请求，或者服务器返回 attachment 头。
        // 既然不能用代理（服务器头不可控），我们尝试前端 Blob 下载。

        statusEl.textContent = '正在连接...';

        try {
            // 尝试 1:通过 Fetch 获取 Blob (触发真正的下载)
            // 这要求目标服务器允许 CORS (部分网易云/QQ CDN 是允许的)
            const response = await fetch(downloadUrl);
            if (!response.ok) throw new Error("Network response was not ok");

            // --- 进度条实现 (Stream Reading) ---
            const contentLength = response.headers.get('content-length');
            const total = parseInt(contentLength, 10);
            let loaded = 0;

            const reader = response.body.getReader();
            const chunks = [];

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                chunks.push(value);
                loaded += value.length;

                // 更新进度条
                if (total) {
                    const percent = Math.round((loaded / total) * 100);
                    if (progressBar) progressBar.style.width = percent + '%';
                    if (statusEl) statusEl.textContent = `下载中 ${percent}%`;
                } else {
                    // 如果没有 Content-Length，显示已下载大小
                    if (statusEl) statusEl.textContent = `下载中 ${(loaded / 1024 / 1024).toFixed(2)} MB`;
                }
            }

            const blob = new Blob(chunks);
            const blobUrl = URL.createObjectURL(blob);

            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = filename; // 这里的 filename 是 "歌手 - 歌名.ext"
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);

            // 释放内存
            setTimeout(() => URL.revokeObjectURL(blobUrl), 10000);
            statusEl.textContent = '下载完成 ✓';
            if (progressBar) progressBar.style.width = '100%';

        } catch (corsError) {
            console.warn("[Download] Blob Download Failed (CORS?), falling back to Direct Link:", corsError);

            // 尝试 2: 降级为新标签页打开 (浏览器默认播放，用户需右键另存为)
            // 这是唯一的纯前端直连兜底方案
            statusEl.textContent = '跨域限制，已打开链接';

            const a = document.createElement('a');
            a.href = downloadUrl;
            a.target = '_blank';
            a.rel = 'noreferrer';
            // 尝试加 download 属性 (虽然跨域时浏览器常忽略)
            a.setAttribute('download', filename);

            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        setTimeout(() => { progressContainer.style.display = 'none'; }, 2500);
        btn.innerHTML = originalText;
        return;

    } catch (e) {
        console.error(e);
        const progressContainer = document.getElementById('download-progress-sidebar');
        const statusEl = document.getElementById('download-status-sidebar');
        if (statusEl) statusEl.textContent = '下载失败 ✗';
        setTimeout(() => {
            if (progressContainer) progressContainer.style.display = 'none';
        }, 2000);
        btn.innerHTML = `<span style="color:#ff5555">下载失败</span>`;
        setTimeout(() => { btn.innerHTML = originalText; }, 1500);
    }
}
