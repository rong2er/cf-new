async function smartMatchNetease(name, artist) {
    try {
        const query = `${name} ${artist || ''}`.trim();
        const d = await req(`${API_CF_WORKER}/v1/query/index.db?keywords=${encodeURIComponent(query)}&limit=1`);
        const songs = findSongArray(d);
        if (songs && songs.length > 0) {
            const match = songs[0];
            let picUrl = match.pic || match.picUrl || (match.al && match.al.picUrl) || (match.album && match.album.picUrl) || "";
            if (picUrl) picUrl = picUrl.replace('http://', 'https://');

            // 返回完整信息以供UI渲染
            // 兼容Netease原始结构 (ar/al) 和标准化结构
            const artistName = match.ar ? match.ar.map(a => a.name).join('/') : (match.artists ? match.artists.map(a => a.name).join('/') : (match.artist || "Unknown"));
            const albumName = match.al ? match.al.name : (match.album ? match.album.name : "");

            return {
                id: match.id,
                name: match.name,
                artist: artistName,
                album: albumName,
                pic: picUrl,
                duration: (typeof formatDuration === 'function') ? formatDuration(match.dt || match.duration || 0) : (match.dt || match.duration || 0),
                source: 'netease' // 强制标记源
            };
        }
    } catch (e) { } return null;
}

async function doSearch(kw, forceSrc) {
    if (!kw) return;

    // Lock Blur: Prevent auto-focus/debounce from re-enabling blur during search
    window.isExecutingSearch = true;
    setTimeout(() => { window.isExecutingSearch = false; }, 1500); // Release lock after 1.5s

    // Manual History Push before Search (Context Change)
    if (typeof pushNavState === 'function') pushNavState();

    if (!document.getElementById('view-discover').classList.contains('active')) switchView('discover');
    document.getElementById('searchInput').blur();

    // Fix: Explicitly remove blur overlay (with delay to beat race conditions)
    if (window.toggleSearchBlur) {
        window.toggleSearchBlur(false);
        // Backup: Ensure it stays off if focus events race
        setTimeout(() => window.toggleSearchBlur(false), 200);
    }

    // Auto-Clear Input as requested
    document.getElementById('searchInput').value = '';
    document.getElementById('searchInput').blur(); // Ensure blur again just in case

    document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity:0.6"><i class="fas fa-spinner fa-spin"></i> 搜索中...</div>';

    try {
        let songs = [];
        const targetSrc = forceSrc || state.src;
        console.log(`正在搜索: ${targetSrc} - ${kw}`);

        // --- 1. 网易云: 使用自建API (wy.omg666.eu.org) ---
        if (targetSrc === 'netease') {
            // 用户提示：恢复使用 CF Worker 进行网易云搜索
            const d = await req(`${API_CF_WORKER}/v1/query/index.db?keywords=${encodeURIComponent(kw)}&limit=100`);
            if (d) { songs = findSongArray(d); songs.forEach(s => s.source = 'netease'); }
        }
        // --- 2. QQ: 使用自建 Worker 代理官方接口 ---
        else if (targetSrc === 'qq') {
            try {
                // 调用 Worker 新增的 /qq/search 接口 (聚合请求 200 条 + 去重)
                const res = await req(`${API_CF_WORKER}/qq/search?keywords=${encodeURIComponent(kw)}&page=1&limit=200`);
                console.log("QQ Worker Search:", res);

                let rawList = [];
                // QQ musicu.fcg 接口返回结构: req_1.data.body.song.list
                if (res && res.req_1 && res.req_1.data && res.req_1.data.body && res.req_1.data.body.song && res.req_1.data.body.song.list) {
                    rawList = res.req_1.data.body.song.list;
                }
                // 兼容旧接口结构 (以防Worker未更新)
                else if (res && res.data && res.data.song && res.data.song.list) {
                    rawList = res.data.song.list;
                }

                if (rawList.length > 0) {
                    songs = rawList.map(item => {
                        // 歌手名处理 (musicu: item.singer)
                        let artistName = "未知歌手";
                        if (item.singer && Array.isArray(item.singer)) {
                            artistName = item.singer.map(s => s.name).join('/');
                        }

                        // ID 和 封面 (兼容 musicu: item.mid / Mobile: item.songmid)
                        const songId = item.mid || item.file?.media_mid || item.songmid;

                        // 专辑封面
                        const albumMid = (item.album && item.album.mid) || item.albummid;
                        const albumName = (item.album && item.album.name) || item.albumname || "未知专辑";

                        // 歌曲名
                        const songName = item.name || item.title || item.songname;

                        // 时长 (QQ返回的是秒，formatDuration通常需要毫秒)
                        const duration = (item.interval ? item.interval * 1000 : 0) || item.dt || 0;

                        let picUrl = "";
                        if (albumMid) {
                            picUrl = `https://y.gtimg.cn/music/photo_new/T002R300x300M000${albumMid}.jpg`;
                        }

                        return {
                            id: songId,
                            name: songName,
                            artist: artistName,
                            album: albumName,
                            pic: picUrl,
                            source: 'qq',
                            duration: formatDuration(duration || 0)
                        };
                    });
                } else {
                    console.warn("QQ Search returned empty list");
                }
            } catch (e) {
                console.error("QQ Worker Search Failed:", e);
                document.getElementById('song-list').innerHTML = `<div style="text-align:center;padding:20px;opacity:0.6">QQ 搜索失败: ${e.message}</div>`;
            }
        }
        // --- 3. 兜底 (其他情况) ---
        else {
            const d = await req(`${API_BACKUP}?types=search&count=50&source=${targetSrc}&name=${encodeURIComponent(kw)}`);
            if (d) { songs = findSongArray(d); songs.forEach(s => s.source = targetSrc); }
        }

        // 渲染结果
        if (songs.length > 0) {
            const validSongs = songs.filter(s => s.id && s.name);
            if (validSongs.length > 0) {
                fmtList(validSongs, 'discover');
            } else {
                document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity:0.6">数据解析为空 (格式不兼容)</div>';
            }
        } else {
            document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity:0.6">未找到相关歌曲</div>';
        }

    } catch (e) {
        console.error("搜索出错:", e);
        document.getElementById('song-list').innerHTML = `<div style="text-align:center;padding:20px;opacity:0.6">搜索请求失败: ${e.message}</div>`;
    }
}

async function doSmartAlbumSearch(kw, targetArtist, targetAlbum) {
    if (!kw) return;
    switchView('discover'); document.getElementById('searchInput').value = targetAlbum + " (专辑)";
    document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity=0.6">正在解析专辑...</div>';
    const queryName = targetArtist + " " + kw;
    const d = await req(`${API_CF_WORKER}/v1/query/index.db?keywords=${encodeURIComponent(queryName)}&limit=40`);
    const rawList = findSongArray(d);
    const processedList = processRawSongs(rawList);
    const cleanList = processedList.filter(s => {
        const tAlbum = String(targetAlbum).toLowerCase().trim();
        const sAlbum = String(s.album).toLowerCase().trim();
        return sAlbum.includes(tAlbum) || tAlbum.includes(sAlbum);
    });
    if (cleanList.length > 0) { state.list = cleanList; state.pg.discover = 0; renderList('discover'); }
    else { if (kw === queryName) document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity=0.6">未找到专辑内容</div>'; else doSmartAlbumSearch(kw, "", targetAlbum); }
}

async function loadSheet(id, retry = 0) {
    if (!/^\d+$/.test(id)) { await doSearch(id, 'netease'); return; }
    document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity=0.6">加载榜单中...</div>';
    try {
        const d = await req(`${API_CF_WORKER}/v1/schema/latest.json?id=${id}&_t=${Date.now()}`);
        const songs = findSongArray(d);
        if (songs.length === 0 && retry < 3) {
            document.getElementById('song-list').innerHTML = `<div style="text-align:center;padding:20px;opacity=0.6">网络波动，正在重试 (${retry + 1}/3)...</div>`;
            setTimeout(() => loadSheet(id, retry + 1), 1500); return;
        }
        songs.forEach(s => s.source = 'netease');
        if (songs.length > 0) fmtList(songs, 'discover'); else document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity=0.6">榜单内容为空</div>';
    } catch (e) { document.getElementById('song-list').innerHTML = '<div style="text-align:center;padding:20px;opacity=0.6">加载出错</div>'; }
}

async function loadToplists() {
    if (state.toplistLoaded) return;
    const container = document.getElementById('toplist-grid');
    container.innerHTML = '<div style="grid-column:1/-1;text-align:center;opacity=0.6;padding:40px"><i class="fas fa-spinner fa-spin"></i> 正在获取榜单数据...</div>';
    try {
        const res = await req(`${API_CF_WORKER}/v1/index/rank.json?_t=${Date.now()}`);
        if (!res) { container.innerHTML = '<div style="grid-column:1/-1;text-align:center;opacity=0.6">网络请求失败</div>'; return; }
        const list = res.list || [];
        if (list.length > 0) {
