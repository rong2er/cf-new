async function loadArtistAlbums(artistId, reset = false) {
    const albumsContainer = document.getElementById('artist-albums-grid');
    const pgContainer = document.getElementById('pg-artist-albums');
    const pgInfo = document.getElementById('pg-info-artist-albums');

    if (reset || !state.artistAlbums || state.artistAlbums.id !== artistId) {
        state.artistAlbums = {
            id: artistId,
            offset: 0,
            limit: 32, // 4行 x 8列
            all: [], // 缓存当前页
            total: 0
        };
    }

    if (state.artistAlbums.all.length === 0) {
        albumsContainer.innerHTML = renderArtistSkeleton(32);
        pgContainer.style.display = 'none';
    }

    try {
        const limit = state.artistAlbums.limit;
        const offset = state.artistAlbums.offset;
        const res = await req(`${API_CF_WORKER}/v1/data/album_list.bin?id=${artistId}&limit=${limit}&offset=${offset}`);

        if (res && res.hotAlbums && res.hotAlbums.length > 0) {
            const html = res.hotAlbums.map(album => {
                const picUrl = (album.picUrl || album.blurPicUrl || '').replace(/^http:/, 'https:');
                return `<div class="tile lazy-loading" 
                            style="--img: url('${PLACEHOLDER_IMG}')" 
                            data-lazy-img="${picUrl}"
                            onclick="loadAlbumDetail(${album.id}, '${(album.name || '').replace(/'/g, "\\'")}', ${artistId})">
                            <div class="tile-text">${album.name}</div>
                            <div class="tile-badge">${formatDate(album.publishTime)}</div>
                            <div class="tile-count-badge">${album.size}首</div>
                        </div>`;
            }).join('');

            albumsContainer.innerHTML = html;

            const currentPage = Math.floor(offset / limit) + 1;
            pgInfo.innerText = `第 ${currentPage} 页`;
            pgContainer.style.display = 'flex';

            setTimeout(() => observeLazyTiles(), 100);

        } else {
            albumsContainer.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">暂无专辑数据</div>';
            if (offset === 0) {
                pgContainer.style.display = 'none';
            } else {
                const currentPage = Math.floor(offset / limit) + 1;
                pgInfo.innerText = `第 ${currentPage} 页 (End)`;
                pgContainer.style.display = 'flex';
            }
        }
    } catch (e) {
        console.error('加载专辑失败:', e);
        albumsContainer.innerHTML = '<div style="grid-column: 1 / -1; text-align:center;opacity:0.6;padding:40px">加载失败，请重试</div>';
        if (state.artistAlbums.offset > 0) {
            pgContainer.style.display = 'flex';
        } else {
            pgContainer.style.display = 'none';
        }
    }
}

