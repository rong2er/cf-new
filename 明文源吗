    async probeUrl(url) {
        if (!url) return 0;
        try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 3000);
            
            let targetUrl = url;
            if (url.includes('.music.126.net') || url.includes('.myqcloud.com') || url.includes('music.163.com')) {
                targetUrl = `${API_CF_WORKER}/util/download?url=${encodeURIComponent(url)}&filename=probe.mp3`;
            }

            const response = await fetch(targetUrl, { method: 'HEAD', signal: controller.signal });
            clearTimeout(timeoutId);
            const len = response.headers.get('content-length');
            if (len) return parseInt(len, 10);
            
            const controller2 = new AbortController();
            const timeoutId2 = setTimeout(() => controller2.abort(), 3000);
            const response2 = await fetch(targetUrl, { method: 'GET', signal: controller2.signal, headers: { 'Range': 'bytes=0-0' } });
            clearTimeout(timeoutId2);
            const len2 = response2.headers.get('content-range');
            if (len2) {
                const total = len2.split('/')[1];
                if (total) return parseInt(total, 10);
            }
            return 0;
        } catch (e) { return 0; }
    }

